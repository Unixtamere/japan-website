# Copy this file to ".env" and paste in your key, then restart `npm run dev`.
#
# Free flight-status key from AeroDataBox on RapidAPI:
#   1. Sign up at https://rapidapi.com/
#   2. Subscribe (free Basic tier) to AeroDataBox:
#      https://rapidapi.com/aedbx-aedbx/api/aerodatabox
#   3. Copy your "X-RapidAPI-Key" value below.
AERODATABOX_KEY=

# Passcode that unlocks editing the shared trip (add/remove activities,
# photos, videos). Pick something private — anyone with it can edit.
EDIT_PASSCODE=
